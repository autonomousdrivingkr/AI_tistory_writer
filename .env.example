# === LLM API 키 ===
# config.json 의 llm.provider 가 가리키는 키만 있으면 됩니다.

# (무료) Google Gemini API 키 — https://aistudio.google.com/apikey 에서 발급
GEMINI_API_KEY=여기에_Gemini_키_입력

# (유료) Anthropic(Claude) API 키 — https://console.anthropic.com 에서 발급
# 유료 전환 시 config.json 의 provider 를 "claude" 로 바꾸고 아래 키를 채우세요.
ANTHROPIC_API_KEY=sk-ant-여기에_키_입력

# === 본문 사진 (선택) ===
# (무료) Pexels API 키 — https://www.pexels.com/api/ 에서 발급
# config.json 의 images.enabled=true 일 때 본문에 관련 사진을 자동 삽입합니다.
# 키가 없으면 사진 없이 글만 발행됩니다(에러 아님).
PEXELS_API_KEY=여기에_Pexels_키_입력

# (GitHub Actions 전용) 저장된 로그인 세션을 base64로 인코딩한 값
# 로컬에서는 비워두세요. scripts/export-session.js 로 생성합니다.
# TISTORY_STORAGE_STATE=
